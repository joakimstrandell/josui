{
  "name": "@josui/cli",
  "version": "0.2.0",
  "description": "CLI tools for josui",
  "bin": {
    "josui": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack src/index.ts src/vite.ts --dts",
    "dev": "vp pack src/index.ts src/vite.ts --dts --watch",
    "lint": "vp lint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0"
  },
  "devDependencies": {
    "@josui/typescript-config": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
